###############################################################################
#  .env.example — Template for new deployments
#
#  PROFILE SYSTEM:
#    .env.local    Local dev (Ollama, local Qdrant)  — default profile
#    .env.dev      Deployment (OpenRouter, Qdrant Cloud)
#
#  Switch with one variable:
#    RAG_ENV=local   →  loads .env.local   (default)
#    RAG_ENV=dev     →  loads .env.dev
#
#  The env file is the SINGLE SOURCE OF TRUTH for all settings.
#  config.py only defines the schema — it has no operational defaults.
#  Copy this file to .env.local / .env.dev and fill in ALL values.
###############################################################################

# ── API ──────────────────────────────────────────────────────────────────────
RAG_APP_NAME=rag-pipeline
RAG_APP_VERSION=1.0.0
RAG_DEBUG=true
RAG_HOST=0.0.0.0
RAG_PORT=8000
RAG_LOG_LEVEL=INFO
RAG_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Qdrant ───────────────────────────────────────────────────────────────────
# Local:  RAG_QDRANT_HOST=localhost
# Cloud:  RAG_QDRANT_HOST=https://xxx.cloud.qdrant.io:6333  RAG_QDRANT_API_KEY=...
RAG_QDRANT_HOST=localhost
RAG_QDRANT_PORT=6333
# RAG_QDRANT_API_KEY=
RAG_QDRANT_COLLECTION=documents
RAG_QDRANT_TIMEOUT=60

# ── GCP ──────────────────────────────────────────────────────────────────────
RAG_GCP_PROJECT_ID=your-gcp-project-id
RAG_GCS_BUCKET=rag-documents
RAG_FIRESTORE_DATABASE=ai-rag-firestore

# ── Google OAuth ─────────────────────────────────────────────────────────────
RAG_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
RAG_GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── JWT ──────────────────────────────────────────────────────────────────────
RAG_JWT_SECRET_KEY=change-me-to-a-long-random-string-in-production
RAG_JWT_EXPIRATION_HOURS=24

# ── LLM ─────────────────────────────────────────────────────────────────────
# Primary:  fireworks (recommended)  — fast, cheap, OpenAI-compatible
# Fallback: openrouter               — broad model coverage
#
# Fireworks model format: accounts/fireworks/models/<model-id>
# Browse models: https://fireworks.ai/models
#
# Local dev (Ollama): RAG_LLM_PROVIDER=ollama  RAG_OLLAMA_MODEL=qwen3:4b
RAG_LLM_PROVIDER=fireworks
RAG_LLM_FALLBACK_PROVIDER=openrouter
RAG_LLM_MAX_RETRIES=3
RAG_LLM_TIMEOUT=60.0

# Fireworks AI (primary)
RAG_FIREWORKS_API_KEY=fw_...
RAG_FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v3p1
# RAG_FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1  # default, no need to set

# OpenRouter (fallback)
RAG_OPENROUTER_API_KEY=sk-or-v1-...
RAG_OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
RAG_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama (local dev only)
RAG_OLLAMA_MODEL=qwen3:4b
RAG_OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (optional, if needed)
# RAG_OPENAI_API_KEY=sk-...
# RAG_OPENAI_MODEL=gpt-4o-mini

# ── Embeddings ───────────────────────────────────────────────────────────────
# Local:  RAG_EMBEDDING_PROVIDER=ollama      RAG_EMBEDDING_MODEL=nomic         (768d)
# Dev:    RAG_EMBEDDING_PROVIDER=openrouter  RAG_EMBEDDING_MODEL=nvidia-nemotron (2048d, free)
RAG_EMBEDDING_PROVIDER=ollama
RAG_EMBEDDING_MODEL=nomic
RAG_EMBEDDING_API_MODEL=nomic-embed-text:latest
RAG_EMBEDDING_API_FORMAT=openai
RAG_EMBEDDING_BATCH_SIZE=32

# ── Retrieval ────────────────────────────────────────────────────────────────
RAG_DENSE_TOP_K=20
RAG_SPARSE_TOP_K=20
RAG_RERANK_TOP_K=5
RAG_RRF_K=60
RAG_RERANKER_ENABLED=true

# ── Docling (PDF parsing) ───────────────────────────────────────────────────
# "full"   = all models, batch_size=4, best accuracy (~1.5 GB RAM)
# "medium" = batch_size=2, force_backend_text=True (~800-900 MB RAM)
# "slim"   = batch_size=1, fast table mode, force_backend_text (~600 MB RAM)
RAG_DOCLING_MODE=full
# Layout model: "heron" (default, 42.9M params) or "egret_medium" (19.5M params, ~54 MB lighter)
RAG_DOCLING_LAYOUT_MODEL=egret_medium
# Pages per subprocess batch: fresh OS process per batch → ONNX C++ memory fully freed between batches
RAG_DOCLING_PAGES_PER_BATCH=25
RAG_DOCLING_DO_TABLE_STRUCTURE=true
RAG_DOCLING_TABLE_MODE=accurate
RAG_DOCLING_DO_CELL_MATCHING=true
RAG_DOCLING_DOCUMENT_TIMEOUT=1800.0
RAG_DOCLING_NUM_THREADS=1
RAG_DOCLING_DEVICE=auto

# ── Chunking ─────────────────────────────────────────────────────────────────
RAG_CHUNKING_STRATEGY=docling_hybrid
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=128
RAG_MIN_CHUNK_CHARS=200
RAG_MAX_CHUNKS_PER_DOCUMENT=10000

# ── RAG Strategy ─────────────────────────────────────────────────────────────
RAG_RAG_STRATEGY=adaptive

# ── Prompts ──────────────────────────────────────────────────────────────────
RAG_PROMPT_VERSION=v1

# ── Guardrails ───────────────────────────────────────────────────────────────
RAG_GUARDRAILS_ENABLED=true
RAG_MAX_INPUT_LENGTH=2000

# ── Monitoring: Langfuse (optional) ─────────────────────────────────────────
RAG_LANGFUSE_ENABLED=false
# RAG_LANGFUSE_PUBLIC_KEY=pk-lf-...
# RAG_LANGFUSE_SECRET_KEY=sk-lf-...
# RAG_LANGFUSE_HOST=https://cloud.langfuse.com

# ── Evaluation ───────────────────────────────────────────────────────────────
RAG_BENCHMARK_DATASET_PATH=app/evaluation/data/benchmark_dataset.json

# ── Redis / Rate Limiting ─────────────────────────────────────────────────────
# Set RAG_REDIS_URL to blank ("") to disable Redis — rate limiting becomes a no-op.
# Cloud (Redis Labs / Upstash): redis://<username>:<password>@<host>:<port>/0
# Local:                        redis://localhost:6379/0
RAG_REDIS_URL=redis://user:pass@instance:port/0
RAG_RATE_LIMIT_DOCS=3
RAG_RATE_LIMIT_QUERIES=15
# JSON list of email addresses exempted from all rate limits.
# These are seeded into the Redis SET "rl:exempt" at startup (idempotent).
# You can also add/remove entries directly:
#   redis-cli SADD rl:exempt admin@example.com
#   redis-cli SREM rl:exempt user@example.com
#   redis-cli SMEMBERS rl:exempt
RAG_RATE_LIMIT_EXEMPT_EMAILS="abc@gmail.com,xyz@gmail.com"
